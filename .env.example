# Server
PORT=3000
NODE_ENV=development

# Site
SITE_TITLE=My Blog
SITE_SUBTITLE=A beautiful blog
SITE_DESCRIPTION=A blog about life and tech
SITE_AUTHOR=Author Name
SITE_URL=http://localhost:3000
SITE_ROOT=/

# Theme Config
LANGUAGE=en
TIMEZONE=Asia/Shanghai

# Features
ENABLE_LOCAL_SEARCH=true
ENABLE_HITOKOTO=true
ENABLE_MATHJAX=false
ENABLE_GITALK=false
ENABLE_AUTOPLAY_AUDIO=false

# External Services
GOOGLE_ANALYTICS_ID=
GITALK_CLIENT_ID=
GITALK_CLIENT_SECRET=
GITALK_REPO=
GITALK_OWNER=
GITALK_ADMIN=

# Beian (Chinese ICP)
ENABLE_BEIAN=false
BEIAN_INFO=
BEIAN_LINK=

# Pagination
POSTS_PER_PAGE=10

# Cache
ENABLE_CACHE=true
CACHE_TTL=3600

# ==================== PHASE 3 DATABASE CONFIGURATION ====================

# PostgreSQL Database (Vercel Postgres recommended for production)
# For development: postgresql://user:password@localhost:5432/diaspora
# For Vercel: Get from Vercel dashboard
DATABASE_URL="postgresql://user:password@localhost:5432/diaspora"

# Admin Authentication
ADMIN_PASSWORD="admin123"

# Google Analytics
NUXT_PUBLIC_GA4_ID="G-XXXXXXXXXX"

# Email Services (Newsletter Integration)
# Mailchimp Configuration
MAILCHIMP_API_KEY=""
MAILCHIMP_LIST_ID=""
MAILCHIMP_SERVER_PREFIX=""

# SendGrid Configuration (Alternative)
SENDGRID_API_KEY=""

# Image Upload Configuration
UPLOAD_DIR="./public/uploads"
MAX_IMAGE_SIZE=5242880  # 5MB in bytes

# Cloudinary (Optional, for image hosting)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Application URLs
NUXT_PUBLIC_SITE_URL="http://localhost:3000"
NUXT_PUBLIC_SITE_NAME="Diaspora"
