# Server
PORT=3000
NODE_ENV=development

# Site
SITE_TITLE=My Blog
SITE_SUBTITLE=A beautiful blog
SITE_DESCRIPTION=A blog about life and tech
SITE_AUTHOR=Author Name
SITE_URL=http://localhost:3000
SITE_ROOT=/

# Theme Config
LANGUAGE=en
TIMEZONE=Asia/Shanghai

# Features
ENABLE_LOCAL_SEARCH=true
ENABLE_HITOKOTO=true
ENABLE_MATHJAX=false
ENABLE_GITALK=false
ENABLE_AUTOPLAY_AUDIO=false

# External Services
GOOGLE_ANALYTICS_ID=
GITALK_CLIENT_ID=
GITALK_CLIENT_SECRET=
GITALK_REPO=
GITALK_OWNER=
GITALK_ADMIN=

# Beian (Chinese ICP)
ENABLE_BEIAN=false
BEIAN_INFO=
BEIAN_LINK=

# Pagination
POSTS_PER_PAGE=10

# Cache
ENABLE_CACHE=true
CACHE_TTL=3600
