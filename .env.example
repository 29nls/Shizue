# Server
PORT=3000
NODE_ENV=development

# Site
SITE_TITLE=MACENG MARKET
SITE_SUBTITLE=Dragon Nest Item Store
SITE_DESCRIPTION=Toko item Dragon Nest terlengkap dan terpercaya
SITE_AUTHOR=MACENG MARKET
SITE_URL=http://localhost:3000
SITE_ROOT=/

# Theme Config
LANGUAGE=id
TIMEZONE=Asia/Jakarta

# Features
ENABLE_LOCAL_SEARCH=true
ENABLE_REVIEWS=true
ENABLE_WISHLIST=true
ENABLE_NOTIFICATIONS=true

# External Services
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Payment Gateway (Phase 2)
# STRIPE_KEY=
# MIDTRANS_KEY=

# Image Upload Configuration
# Database
DATABASE_URL="file:./dev.db"

# Admin Authentication
ADMIN_PASSWORD="change-me-in-production"

# Google Analytics
NUXT_PUBLIC_GA4_ID="G-XXXXXXXXXX"

# Email Services (Newsletter/Notifications)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# Image Upload ConfigurationUPLOAD_DIR=\"./public/uploads\"
MAX_IMAGE_SIZE=5242880

# Application URLs
NUXT_PUBLIC_SITE_URL=\"http://localhost:3000\"
NUXT_PUBLIC_SITE_NAME=\"MACENG MARKET\"