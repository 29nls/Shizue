<!-- Error page -->
<!DOCTYPE html>
<html lang="<%= config.site.language %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= status %> - <%= config.site.title %></title>
  <link rel="stylesheet" href="<%= config.site.root %>css/diaspora.css" />
  <style>
    .error-page {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      text-align: center;
    }
    .error-content h1 {
      font-size: 4em;
      margin: 20px 0;
    }
    .error-content p {
      font-size: 1.2em;
      color: #666;
      margin: 20px 0;
    }
    .error-content a {
      display: inline-block;
      margin-top: 20px;
      padding: 10px 20px;
      background: #333;
      color: white;
      text-decoration: none;
      border-radius: 4px;
    }
  </style>
</head>
<body>
  <div class="error-page">
    <div class="error-content">
      <h1><%= status %></h1>
      <p><%= message %></p>
      <a href="<%= config.site.root %>">← Back to Home</a>
    </div>
  </div>
</body>
</html>
