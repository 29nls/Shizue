<!DOCTYPE html>
<html lang="<%= config.site.language %>" class="loading">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
  <meta name="viewport" content="width=device-width, minimum-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="google" content="notranslate" />
  
  <title><%= pageTitle %></title>
  <meta name="keywords" content="<%= config.site.keywords %>" />
  <meta name="description" content="<%= config.site.description %>" />
  <meta name="author" content="<%= config.site.author %>">
  
  <!-- Apple Icons -->
  <link rel="apple-touch-icon-precomposed" sizes="144x144" href="<%= config.site.root %>img/144.png">
  <link rel="apple-touch-icon-precomposed" sizes="114x114" href="<%= config.site.root %>img/114.png">
  <link rel="apple-touch-icon-precomposed" sizes="72x72" href="<%= config.site.root %>img/72.png">
  <link rel="apple-touch-icon-precomposed" href="<%= config.site.root %>img/57.png">
  <link rel="icon" type="image/png" href="<%= config.site.root %>img/32.png" />
  
  <style>
    .image-logo { background-image: url(<%= config.site.root %>img/logo.png) }
    body.mu .image-logo { background-image: url(<%= config.site.root %>img/logo_black.png) }
    .image-icon { background-image: url(<%= config.site.root %>img/logo_min.png) }
  </style>
  
  <link rel="stylesheet" href="<%= config.site.root %>css/diaspora.css" />
  <link rel="stylesheet" href="<%= config.site.root %>css/genshin-loader.css" />
  <link rel="stylesheet" href="<%= config.site.root %>css/genshin-polish.css" />
  
  <!-- MathJax -->
  <% if (config.features.mathjax) { %>
    <script src="https://polyfill.io/v3/polyfill.min.js?features=es6"></script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
  <% } %>
</head>
<body class="loading">
  <!-- Advanced Genshin Loading Screen -->
  <div id="genshin-loader">
    <div class="loader-particles">
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
    </div>
    <div class="loader-main">
      <div class="loader-glow"></div>
      <div class="loader-icon">
        <svg viewBox="0 0 100 100" fill="none" stroke="currentColor">
          <circle cx="50" cy="50" r="30" stroke="#f093fb" stroke-width="2"/>
          <path d="M 50 20 Q 70 50 50 80 Q 30 50 50 20" fill="none" stroke="#667eea" stroke-width="2"/>
        </svg>
        <div class="loader-icon-ring"></div>
      </div>
      <div class="loader-line loader-line-1"></div>
      <div class="loader-line loader-line-2"></div>
      <div class="loader-line loader-line-3"></div>
      <div class="loader-line loader-line-4"></div>
    </div>
    <div class="loader-text">
      <h2><%= config.site.title || 'Diaspora' %></h2>
      <p>Loading magical worlds...</p>
    </div>
    <div class="loader-progress">
      <div class="loader-progress-bar"></div>
    </div>
  </div>
  
  <!-- Navigation -->
  <div class="nav">
    <%- include('partials/menu') %>
    <p>&copy; <%= new Date().getFullYear() %> <%= config.site.title %>. Powered by Node.js</p>
  </div>

  <!-- Header/Screen with Hero Image -->
  <div id="screen">
    <%- include('partials/screen') %>
  </div>

  <!-- Main Container -->
  <div id="container">
    <%- body %>
  </div>

  <!-- PhotoSwipe Gallery -->
  <%- include('partials/photoswipe') %>

  <!-- Scripts -->
  <%- include('partials/scripts') %>
</body>
</html>
