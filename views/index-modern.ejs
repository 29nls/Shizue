<!DOCTYPE html>
<html lang="<%= config.site.language %>" class="loading">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
  <meta name="viewport" content="width=device-width, minimum-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="google" content="notranslate" />
  
  <title><%= config.site.title %> - <%= config.site.subtitle %></title>
  <meta name="keywords" content="<%= config.site.keywords %>" />
  <meta name="description" content="<%= config.site.description %>" />
  <meta name="author" content="<%= config.site.author %>">
  
  <!-- Apple Icons -->
  <link rel="apple-touch-icon-precomposed" sizes="144x144" href="<%= config.site.root %>img/144.png">
  <link rel="apple-touch-icon-precomposed" sizes="114x114" href="<%= config.site.root %>img/114.png">
  <link rel="apple-touch-icon-precomposed" sizes="72x72" href="<%= config.site.root %>img/72.png">
  <link rel="apple-touch-icon-precomposed" href="<%= config.site.root %>img/57.png">
  <link rel="icon" type="image/png" href="<%= config.site.root %>img/32.png" />
  
  <!-- Main CSS -->
  <link rel="stylesheet" href="<%= config.site.root %>css/diaspora.css" />
  <link rel="stylesheet" href="<%= config.site.root %>css/modern-home.css" />
</head>
<body class="modern-home">
  <div id="loader"></div>
  
  <!-- ========== HERO SECTION ========== -->
  <section class="hero-section">
    <div class="hero-background"></div>
    <div class="hero-content">
      <h1><%= config.site.title %></h1>
      <p class="subtitle"><%= config.site.subtitle %></p>
      <p class="subtitle" style="font-size: 1rem; margin-top: -0.5rem;"><%= config.site.description %></p>
      
      <div class="cta-buttons">
        <a href="#featured" class="cta-btn primary">Explore Posts</a>
        <a href="#categories" class="cta-btn secondary">Browse Categories</a>
      </div>
    </div>
    
    <div class="scroll-indicator">
      <svg viewBox="0 0 24 24">
        <path d="M12 2v16m0 0l-4-4m4 4l4-4"/>
      </svg>
    </div>
  </section>

  <!-- ========== FEATURED CAROUSEL ========== -->
  <section class="featured-section" id="featured">
    <div class="section-title scroll-fade">
      <h2>Featured Posts</h2>
      <p>Latest and most popular stories</p>
    </div>

    <div class="carousel-container">
      <div class="carousel">
        <% if (posts && posts.length > 0) { %>
          <% posts.slice(0, 6).forEach((post, index) => { %>
            <div class="carousel-item scroll-fade" data-link="<%= config.site.root %>post/<%= post.slug %>">
              <div class="carousel-item-image">
                <img src="<%= post.cover %>" alt="<%= post.title %>" />
              </div>
              <div class="carousel-item-content">
                <span class="carousel-item-date"><%= helpers.formatDate(post.date, 'MMM DD, YYYY') %></span>
                <h3 class="carousel-item-title"><%= post.title %></h3>
                <p class="carousel-item-excerpt"><%= post.excerpt %></p>
                <div class="carousel-item-meta">
                  <% if (post.categories && post.categories.length > 0) { %>
                    <% post.categories.slice(0, 2).forEach(cat => { %>
                      <span class="carousel-item-tag"><%= cat %></span>
                    <% }); %>
                  <% } %>
                </div>
              </div>
            </div>
          <% }); %>
        <% } %>
      </div>
    </div>

    <% if (posts && posts.length > 3) { %>
      <div class="carousel-controls">
        <button class="carousel-btn prev">❮</button>
        <button class="carousel-btn next">❯</button>
      </div>
    <% } %>
  </section>

  <!-- ========== STATS SECTION ========== -->
  <section class="stats-section scroll-fade">
    <div class="stats-container">
      <div class="stat-item">
        <span class="stat-number"><%= posts ? posts.length : 0 %></span>
        <span class="stat-label">Published Posts</span>
      </div>
      <div class="stat-item">
        <span class="stat-number"><%= config.site.keywords ? config.site.keywords.split(',').length : 5 %></span>
        <span class="stat-label">Topics Covered</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">∞</span>
        <span class="stat-label">Happy Readers</span>
      </div>
    </div>
  </section>

  <!-- ========== POSTS GRID ========== -->
  <section class="posts-grid-section" id="posts">
    <div class="section-title scroll-fade">
      <h2>All Posts</h2>
      <p>Explore our complete collection</p>
    </div>

    <div class="posts-grid">
      <% if (posts && posts.length > 0) { %>
        <% posts.forEach((post, index) => { %>
          <div class="post-card scroll-fade" data-link="<%= config.site.root %>post/<%= post.slug %>">
            <div class="post-card-image">
              <img src="<%= post.cover %>" alt="<%= post.title %>" />
            </div>
            <div class="post-card-body">
              <% if (post.categories && post.categories.length > 0) { %>
                <span class="post-card-category"><%= post.categories[0] %></span>
              <% } %>
              <h3 class="post-card-title"><%= post.title %></h3>
              <p class="post-card-excerpt"><%= post.excerpt %></p>
              <div class="post-card-footer">
                <span class="post-card-date"><%= helpers.formatDate(post.date, 'MMM DD') %></span>
                <span class="post-card-arrow">→</span>
              </div>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <p style="grid-column: 1 / -1; text-align: center; padding: 2rem;">No posts yet. Check back soon!</p>
      <% } %>
    </div>
  </section>

  <!-- ========== CATEGORIES SECTION ========== -->
  <% if (categories && categories.length > 0) { %>
    <section class="categories-section" id="categories">
      <div class="section-title scroll-fade">
        <h2>Browse by Category</h2>
        <p>Find content that interests you</p>
      </div>

      <div class="categories-grid">
        <% categories.slice(0, 8).forEach(category => { %>
          <div class="category-card scroll-fade" data-link="<%= config.site.root %>category/<%= category %>">
            <div class="category-icon">📁</div>
            <div class="category-name"><%= category %></div>
            <div class="category-count">
              <% const count = posts ? posts.filter(p => p.categories && p.categories.includes(category)).length : 0; %>
              <%= count %> <%= count === 1 ? 'post' : 'posts' %>
            </div>
          </div>
        <% }); %>
      </div>
    </section>
  <% } %>

  <!-- ========== FOOTER ========== -->
  <footer style="background: #1a1a1a; color: white; padding: 2rem; text-align: center;">
    <p>&copy; <%= new Date().getFullYear() %> <%= config.site.title %>. All rights reserved.</p>
    <p style="font-size: 0.9rem; opacity: 0.7; margin-top: 0.5rem;">Powered by Node.js with ❤️</p>
  </footer>

  <!-- Scripts -->
  <script src="<%= config.site.root %>js/jquery.min.js"></script>
  <script src="<%= config.site.root %>js/modern-home.js"></script>

  <script>
    // Remove loading class
    document.documentElement.classList.remove('loading');
    document.body.classList.remove('loading');

    // Add click handlers for cards
    document.querySelectorAll('.carousel-item, .post-card, .category-card').forEach(card => {
      card.addEventListener('click', function() {
        const link = this.getAttribute('data-link');
        if (link) {
          window.location.href = link;
        }
      });
    });
  </script>
</body>
</html>
