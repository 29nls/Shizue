<!-- Pagination -->
<div class="pagination">
  <% if (hasPrev) { %>
    <a href="<%= prevLink %>" class="prev">← Previous</a>
  <% } %>
  
  <span class="page-info">
    Page <%= currentPage %> of <%= totalPages %> (<%= totalPosts %> posts)
  </span>
  
  <% if (hasNext) { %>
    <a href="<%= nextLink %>" class="next">Next →</a>
  <% } %>
</div>
