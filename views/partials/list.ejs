<!-- Post list item -->
<div class="posts">
  <% posts.forEach(post => { %>
    <article class="post-item">
      <% if (post.cover) { %>
        <a href="<%= helpers.urlFor(`/post/${post.slug}`) %>" class="pview">
          <img src="<%= post.cover %>" alt="<%= post.title %>" />
        </a>
      <% } %>
      
      <div class="post-content">
        <h2><a href="<%= helpers.urlFor(`/post/${post.slug}`) %>" class="pview"><%= post.title %></a></h2>
        
        <div class="post-meta">
          <span class="date"><%= helpers.formatDate(post.date, 'YYYY-MM-DD') %></span>
          <% if (post.categories && post.categories.length > 0) { %>
            <span class="categories">
              <% post.categories.forEach((cat, idx) => { %>
                <a href="<%= helpers.urlFor(`/category/${cat}`) %>"><%= cat %></a><% if (idx < post.categories.length - 1) { %>, <% } %>
              <% }); %>
            </span>
          <% } %>
        </div>

        <p class="excerpt"><%= post.excerpt %></p>

        <% if (post.tags && post.tags.length > 0) { %>
          <div class="tags">
            <% post.tags.forEach(tag => { %>
              <a href="<%= helpers.urlFor(`/tag/${tag}`) %>" class="tag">#<%= tag %></a>
            <% }); %>
          </div>
        <% } %>

        <a href="<%= helpers.urlFor(`/post/${post.slug}`) %>" class="read-more pview">Read More →</a>
      </div>
    </article>
  <% }); %>
</div>
