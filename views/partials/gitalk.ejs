<!-- Gitalk Comments -->
<% if (config.features.gitalk && config.services.gitalk.enable) { %>
<div id="gitalk-container"></div>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/gitalk@1/dist/gitalk.css">
<script src="https://cdn.jsdelivr.net/npm/gitalk@1/dist/gitalk.min.js"></script>
<script>
const gitalk = new Gitalk({
  clientID: '<%= config.services.gitalk.clientID %>',
  clientSecret: '<%= config.services.gitalk.clientSecret %>',
  repo: '<%= config.services.gitalk.repo %>',
  owner: '<%= config.services.gitalk.owner %>',
  admin: <%= JSON.stringify(config.services.gitalk.admin) %>,
  id: window.location.pathname,
  labels: ['Gitalk'],
  perPage: 15,
  pagerDirection: 'last',
  distractionFreeMode: false,
});
gitalk.render('gitalk-container');
</script>
<% } %>
