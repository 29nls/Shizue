<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta http-equiv="X-UA-Compatible" content="ie=edge" />

<!-- SEO Meta Tags -->
<title><%= pageTitle %></title>
<meta name="description" content="<%= config.site.description %>" />
<meta name="keywords" content="<%= config.site.keywords %>" />
<meta name="author" content="<%= config.site.author %>" />

<!-- Open Graph -->
<meta property="og:title" content="<%= pageTitle %>" />
<meta property="og:description" content="<%= config.site.description %>" />
<meta property="og:type" content="website" />
<meta property="og:url" content="<%= config.site.url %>" />

<!-- Twitter Card -->
<% if (config.services && config.services.twitterpic && config.services.twitterpic.enable) { %>
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:creator" content="<%= config.services.twitterpic.creatorid %>" />
<% } %>

<!-- Favicon -->
<link rel="icon" href="<%= helpers.urlFor(config.theme.favicon) %>" type="image/png" />

<!-- Styles -->
<link rel="stylesheet" href="<%= helpers.urlFor('/css/diaspora.css') %>" />

<!-- MathJax -->
<% if (config.features.mathjax) { %>
<script src="https://polyfill.io/v3/polyfill.min.js?features=es6"></script>
<script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
<% } %>
