<!-- Hero/Cover Section -->
<div id="mark">
  <div class="layer" data-depth="0.4">
    <img id="cover" crossorigin="anonymous" src="<%= config.theme.welcomeCover || (config.site.root + 'img/cover.jpg') %>" alt="<%= config.site.title %>" />
  </div>
</div>

<!-- Color Overlay -->
<div id="vibrant">
  <div></div>
</div>

<!-- Header with Logo and Menu -->
<div id="header">
  <div>
    <a class="image-logo" href="<%= config.site.root %>"></a>
    <div class="icon-menu"></div>
  </div>
</div>

<!-- Title Section -->
<div id="post0">
  <p><%= config.site.subtitle %></p>
  <h2><a href="<%= config.site.root %>"><%= config.site.title %></a></h2>
  <p><%= config.site.description %></p>
</div>
