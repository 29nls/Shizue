<!-- Single post article partial (for AJAX loading) -->
<article class="post">
  <% if (post.cover) { %>
    <div class="post-cover">
      <img src="<%= post.cover %>" alt="<%= post.title %>" />
    </div>
  <% } %>

  <header class="post-header">
    <h1><%= post.title %></h1>
    
    <div class="post-meta">
      <time datetime="<%= post.date.toISOString() %>">
        <%= helpers.formatDate(post.date, 'YYYY-MM-DD HH:mm:ss') %>
      </time>
      
      <% if (post.categories && post.categories.length > 0) { %>
        <div class="categories">
          <% post.categories.forEach((cat, idx) => { %>
            <a href="<%= helpers.urlFor(`/category/${cat}`) %>"><%= cat %></a><% if (idx < post.categories.length - 1) { %>, <% } %>
          <% }); %>
        </div>
      <% } %>
    </div>
  </header>

  <% if (post.mp3) { %>
    <div class="audio-player">
      <audio controls <% if (post.autoplay) { %>autoplay<% } %>>
        <source src="<%= post.mp3 %>" type="audio/mpeg" />
        Your browser does not support the audio element.
      </audio>
    </div>
  <% } %>

  <div class="post-content">
    <%- post.content %>
  </div>

  <% if (post.tags && post.tags.length > 0) { %>
    <footer class="post-tags">
      <% post.tags.forEach(tag => { %>
        <a href="<%= helpers.urlFor(`/tag/${tag}`) %>" class="tag">#<%= tag %></a>
      <% }); %>
    </footer>
  <% } %>
</article>
