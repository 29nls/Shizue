// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Post model - stores all blog posts
model Post {
  id          String    @id @default(cuid())
  title       String
  excerpt     String?
  slug        String    @unique
  content     String    // Markdown or HTML
  categories  String    @default("")  // Comma-separated or JSON string
  tags        String    @default("")  // Comma-separated or JSON string
  author      String    @default("Admin")
  coverImage  String?   // URL to featured image
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  comments    Comment[]
  views       Int       @default(0)
  
  @@index([slug])
  @@index([published])
  @@index([publishedAt])
}

// Comment model - stores post comments
model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    String
  email     String
  content   String
  approved  Boolean  @default(false)
  isSpam    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([postId])
  @@index([approved])
  @@index([isSpam])
}

// Subscriber model - stores newsletter subscribers
model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  verified  Boolean  @default(false)
  active    Boolean  @default(true)
  mailchimpId String? // ID from Mailchimp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([verified])
  @@index([active])
}

// Image model - tracks uploaded images
model Image {
  id        String   @id @default(cuid())
  filename  String   @unique
  url       String
  postId    String?  // If associated with a post
  size      Int      // File size in bytes
  width     Int?     // Image dimensions
  height    Int?
  alt       String?  // Alt text for accessibility
  createdAt DateTime @default(now())
  
  @@index([postId])
}

// Draft model - auto-saved post drafts
model Draft {
  id        String   @id @default(cuid())
  title     String
  content   String   // Auto-saved content
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([slug])
}

// Analytics model - track page views and events
model Analytics {
  id        String   @id @default(cuid())
  postSlug  String?  // If post-specific
  event     String   // 'pageview', 'search', 'comment', 'subscribe'
  metadata  String?  // JSON metadata
  createdAt DateTime @default(now())
  
  @@index([postSlug])
  @@index([event])
}

// Settings model - site configuration
model Settings {
  id              String   @id @default(cuid())
  siteTitle       String   @default("Diaspora")
  siteDescription String   @default("A beautiful Genshin-inspired blog")
  logo            String?  // URL to logo
  favicon         String?  // URL to favicon
  
  // Newsletter settings
  mailchimpListId String?
  mailchimpApiKey String?
  
  // Email notification settings
  notifyAdminEmail String?
  notifyOnComment  Boolean  @default(true)
  
  // Moderation settings
  autoApproveComments Boolean @default(false)
  spamFilterEnabled   Boolean @default(true)
  
  updatedAt DateTime @updatedAt
}
